# Base URL of the FastAPI backend (Hugging Face Space).
# For local dev against a local backend:
#   NEXT_PUBLIC_API_URL=http://localhost:7860
# In production set this in Vercel project settings to your Space URL, e.g.
#   NEXT_PUBLIC_API_URL=https://<your-name>-tennis-backhand-detector.hf.space
NEXT_PUBLIC_API_URL=http://localhost:7860
